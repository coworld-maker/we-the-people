// prisma/schema.prisma
// Ground-truth schema matching the actual Supabase DB columns.
// datasource has NO url/directUrl so prisma generate never fails on missing env vars.
// Runtime connection is handled by @prisma/adapter-pg (pg.Pool) in lib/prisma.ts.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// User — encrypted email/zip storage
// ---------------------------------------------------------------------------
model User {
  id                 String    @id @default(cuid())
  clerkId            String    @unique
  emailEncrypted     String
  emailIv            String
  emailTag           String
  emailHash          String    @unique
  zipCodeEncrypted   String?
  zipCodeIv          String?
  zipCodeTag         String?
  firstName          String?
  lastName           String?
  profilePublic      Boolean   @default(false)
  votesPublic        Boolean   @default(false)
  emailNotifications Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  votes         Vote[]
  discussions   Discussion[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

// ---------------------------------------------------------------------------
// Bill
// ---------------------------------------------------------------------------
model Bill {
  id               String    @id @default(cuid())
  congress         Int
  billType         String
  billNumber       Int
  title            String
  shortTitle       String?
  summary          String?
  aiSummary        String?
  introducedDate   DateTime
  latestActionDate DateTime?
  latestActionText String?
  status           String
  originChamber    String
  policyArea       String?
  subjects         String[]  @default([])
  sponsors         Json
  cosponsors       Json?
  actions          Json?
  fullText         String?
  aiAnalyzedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  votes         Vote[]
  voteAggregate BillVoteAggregate?
  discussions   Discussion[]
  impacts       Impact[]
  prosCons      ProCon[]
  congressVotes CongressVote[]
  notifications Notification[]

  @@unique([congress, billType, billNumber])
}

// ---------------------------------------------------------------------------
// BillVoteAggregate — denormalized vote counts per bill
// ---------------------------------------------------------------------------
model BillVoteAggregate {
  id           String    @id @default(cuid())
  billId       String    @unique
  yesCount     Int       @default(0)
  noCount      Int       @default(0)
  abstainCount Int       @default(0)
  totalVotes   Int       @default(0)
  lastVoteAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  bill Bill @relation(fields: [billId], references: [id])
}

// ---------------------------------------------------------------------------
// CongressVote — how each member of congress voted on a bill
// ---------------------------------------------------------------------------
model CongressVote {
  id         String    @id @default(cuid())
  bioguideId String
  billId     String
  position   String
  votedAt    DateTime?
  chamber    String?
  rollNumber Int?
  congress   Int?
  session    Int?
  createdAt  DateTime  @default(now())

  bill Bill @relation(fields: [billId], references: [id])

  @@unique([bioguideId, billId])
}

// ---------------------------------------------------------------------------
// Discussion — threaded comments on bills
// ---------------------------------------------------------------------------
model Discussion {
  id        String   @id @default(cuid())
  billId    String
  userId    String
  parentId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bill    Bill         @relation(fields: [billId], references: [id])
  user    User         @relation(fields: [userId], references: [id])
  parent  Discussion?  @relation("DiscussionReplies", fields: [parentId], references: [id])
  replies Discussion[] @relation("DiscussionReplies")
}

// ---------------------------------------------------------------------------
// Impact — AI-generated impact analysis per bill
// ---------------------------------------------------------------------------
model Impact {
  id               String   @id @default(cuid())
  billId           String
  category         String
  demographic      String?
  impactType       String
  shortDescription String
  detailedAnalysis String
  affectedGroups   String[] @default([])
  confidence       Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bill Bill @relation(fields: [billId], references: [id])
}

// ---------------------------------------------------------------------------
// Notification
// ---------------------------------------------------------------------------
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  billId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  bill Bill? @relation(fields: [billId], references: [id])
}

// ---------------------------------------------------------------------------
// ProCon — pros and cons per bill
// ---------------------------------------------------------------------------
model ProCon {
  id          String   @id @default(cuid())
  billId      String
  type        String
  title       String
  description String
  category    String?
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bill Bill @relation(fields: [billId], references: [id])
}

// ---------------------------------------------------------------------------
// Representative
// ---------------------------------------------------------------------------
model Representative {
  id          String   @id @default(cuid())
  bioguideId  String   @unique
  firstName   String
  lastName    String
  fullName    String
  party       String
  state       String
  district    String?
  chamber     String
  termStart   DateTime
  currentTerm Boolean  @default(true)
  committees  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Vote — user votes on bills (encrypted reasoning)
// ---------------------------------------------------------------------------
model Vote {
  id                 String   @id @default(cuid())
  userId             String
  billId             String
  position           String
  reasoningEncrypted String?
  reasoningIv        String?
  reasoningTag       String?
  isAnonymous        Boolean  @default(true)
  confidence         Int?
  ipHash             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  bill Bill @relation(fields: [billId], references: [id])

  @@unique([userId, billId])
}

// ---------------------------------------------------------------------------
// AuditLog
// ---------------------------------------------------------------------------
model AuditLog {
  id            String   @id @default(cuid())
  eventType     String
  severity      String
  userId        String?
  ipAddressHash String?
  metadata      Json?
  message       String?
  timestamp     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
