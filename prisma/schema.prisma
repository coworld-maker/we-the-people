// ============================================================
// PRISMA SCHEMA DIFF — paste these two models into your
// prisma/schema.prisma, replacing the existing CongressVote
// and Representative models.
// ============================================================

model CongressVote {
  id          String   @id
  bioguideId  String
  billId      String
  position    String   // "yea" | "nay" | "not_voting" | "present"
  chamber     String?  // "House" | "Senate"   ← NEW
  rollNumber  Int?     //                       ← NEW
  congress    String?  // e.g. "119"           ← NEW
  session     Int?     // 1 or 2               ← NEW
  votedAt     DateTime
  createdAt   DateTime @default(now())

  @@unique([bioguideId, billId])
}

model Representative {
  id          String    @id @default(cuid())
  bioguideId  String    @unique              // ← ensures upsert works
  firstName   String
  lastName    String
  fullName    String
  party       String    // "D" | "R" | "I"
  state       String
  district    String?   // null for senators
  chamber     String    // "House" | "Senate"
  termStart   DateTime
  currentTerm Boolean   @default(true)
  committees  String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
